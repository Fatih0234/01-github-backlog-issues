# Copy this file to .env and fill in the values before running docker-compose.

# --- GitHub ---
GITHUB_TOKEN=your_github_personal_access_token
REPO_OWNER=apache
REPO_NAME=airflow
# MAX_PAGES=10  # optional, limit bronze extraction pages

# --- GitPulse runtime ---
GITPULSE_STORAGE_BACKEND=s3
# GITPULSE_LOCAL_DATA_ROOT=/tmp/gitpulse-data  # use with GITPULSE_STORAGE_BACKEND=local
DUCKDB_FILE=/tmp/gitpulse.duckdb

# --- MinIO (object storage) ---
MINIO_ENDPOINT=localhost:9000
MINIO_BUCKET=gitpulse
MINIO_ACCESS_KEY=gitpulse
MINIO_SECRET_KEY=gitpulse
MINIO_ROOT_USER=gitpulse
MINIO_ROOT_PASSWORD=gitpulse

# --- Airflow secrets (generate strong random values for production) ---
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=replace-with-a-fernet-key
# python -c "import secrets; print(secrets.token_urlsafe(32))"
AIRFLOW_INTERNAL_API_SECRET_KEY=replace-with-a-random-secret-key
AIRFLOW_JWT_SECRET=replace-with-a-random-jwt-secret
AIRFLOW_WEBSERVER_SECRET_KEY=generate_with_python3_secrets_token_hex_32

# --- Metabase ---
METABASE_URL=http://localhost:3000
METABASE_EMAIL=admin@gitpulse.com
METABASE_PASSWORD=password
