# GitHub
GITHUB_TOKEN=your_github_token_here
REPO_OWNER=apache
REPO_NAME=airflow
# MAX_PAGES=5  # optional, limit for test runs

# MinIO (use localhost:9000 for local runs, minio:9000 inside Docker)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=gitpulse
MINIO_SECRET_KEY=gitpulse
MINIO_BUCKET=gitpulse

# DuckDB (/tmp for local runs, /duckdb/gitpulse.duckdb inside Docker)
DUCKDB_FILE=/tmp/gitpulse.duckdb
