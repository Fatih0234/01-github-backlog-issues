FROM apache/airflow:3.0.0-python3.12

# BashOperator moved to providers-standard in Airflow 3.x.
# Install project dependencies as the airflow user (required by the Airflow base image).
# Source code is volume-mounted at runtime (/opt/airflow/project).
RUN pip install --no-cache-dir \
    "apache-airflow-providers-standard" \
    "requests>=2.32" \
    "python-dotenv>=1.0" \
    "tenacity>=9.0" \
    "duckdb>=1.1" \
    "pyarrow>=16.0" \
    "boto3>=1.34" \
    "pytz"
